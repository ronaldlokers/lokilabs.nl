---
import Base from '../layouts/Base.astro';
import Prompt from '../components/Prompt.astro';

import { jobs as history } from '../data/history';
---
<Base title="about — lokilabs" description="Ronald Lokers — 15 years of frontend and fullstack, now building the pipelines and platforms that keep software boring to deploy.">
  <main id="main" class="wrap page-head">
    <Prompt cmd="cat about.md" />
    <div class="about-head">
      <div class="about-tile"><img src="/assets/face-line-violet.png" alt="Ronald Lokers, line-art portrait" /></div>
      <div>
        <h1>Ronald Lokers</h1>
        <p>Developer in the Netherlands, switched from frontend to platform engineering. If I do something twice, it becomes a script.</p>
        <p style="margin-top: 10px;"><span class="hire-badge">open to platform / devops roles</span></p>
      </div>
    </div>

    <div class="prose" style="max-width: 640px;">
      <p>15 years of frontend and fullstack at Coolblue, Mendix, and Oliver IT. The part I loved was never the UI — it was the pipelines and infrastructure underneath. Since mid-2025 (after a health break, fully under control) I'm all-in on platform engineering.</p>
    </div>

    <p class="seclabel" style="margin: 30px 0 18px;">in practice</p>
    <div class="prose" style="max-width: 640px;">
      <ul>
        <li>Raspberry Pi CM5 Kubernetes cluster, three HA control planes, run like production — GitOps with FluxCD (<a href="https://github.com/ronaldlokers/homelab">repo</a>)</li>
        <li>Prometheus + Grafana observability; Longhorn, MetalLB, Renovate</li>
        <li>Daily: Arch Linux, Docker, CI/CD design, cluster operations</li>
      </ul>
      <p>Ready to bring 15+ years to a Platform or DevOps role. <a href="mailto:ronald@lokilabs.nl">Get in touch</a>.</p>
    </div>

    <p class="seclabel" style="margin: 30px 0 18px;">away from the keyboard</p>
    <div class="prose" style="max-width: 640px;">
      <p>Rally Chief Official and Rescue Marshal at KNAF rallies; Event Traffic Controller at village events in Fijnaart. Different kind of incident response.</p>
    </div>

    <p class="seclabel" style="margin: 34px 0 22px;">work history</p>
    <div class="timeline">
      {history.map((job) => (
        <div class={`tl-item${job.state ? ` ${job.state}` : ''}`}>
          <div class="when">{job.when}</div>
          <div class="role">{job.role} <small>@ {job.org}</small></div>
          {job.desc && <p>{job.desc}</p>}
        </div>
      ))}
    </div>
  </main>
</Base>
