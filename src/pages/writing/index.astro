---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';
import Prompt from '../../components/Prompt.astro';

const posts = (await getCollection('writing', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
import { fmtDate } from '../../lib/date';
const minutes = (body: string | undefined) =>
  Math.max(1, Math.round((body ?? '').split(/\s+/).length / 200));
---
<Base title="writing — lokilabs" description="Posts by Ronald Lokers on platform engineering, automation, and shipping side projects.">
  <main class="wrap page-head">
    <Prompt cmd="ls writing/" />
    <h1>writing</h1>
    <div>
      {posts.map((post) => (
        <a class="postrow" href={`/writing/${post.id}/`}>
          <span class="grow">
            <span class="date">{fmtDate(post.data.pubDate)} · {minutes(post.body)} min</span>
            <span class="t" style="display: block;">{post.data.title}</span>
            <p>{post.data.description}</p>
            {post.data.tags.length > 0 && <span class="tags" style="display: flex; gap: 6px; margin-top: 10px;">{post.data.tags.map((t) => <span class="tag">{t}</span>)}</span>}
          </span>
          <span class="go">→</span>
        </a>
      ))}
    </div>
  </main>
</Base>
