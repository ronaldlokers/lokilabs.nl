---
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';
import Prompt from '../components/Prompt.astro';

const projects = (await getCollection('projects', ({ data }) => !data.draft))
  .sort((a, b) => a.data.order - b.data.order)
  .slice(0, 2);
const posts = (await getCollection('writing', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);
const iso = (d: Date) => d.toISOString().slice(0, 10);
const host = (url: string) => new URL(url).host;
---
<Base
  title="lokilabs — Ronald Lokers"
  description="Developer & indie hacker. I build small tools, ship side projects, and write about the process."
>
  <section class="hero">
    <div class="wrap">
      <div class="hero-tile"><img src="/assets/face-line-violet.png" alt="Ronald Lokers, line-art portrait" /></div>
      <div style="flex: 1;">
        <Prompt cmd="whoami" purple />
        <h1>Do it twice?<br />I'll automate it<span class="cursor" aria-hidden="true"></span></h1>
        <p class="sub">Developer &amp; indie hacker. I build small tools, ship side projects, and write about the process.</p>
        <div class="btn-row">
          <a class="btn" href="/projects/">view projects →</a>
          <a class="btn ghost" href="https://github.com/ronaldlokers">github</a>
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="wrap">
      <p class="seclabel">selected work</p>
      <div class="workgrid">
        {projects.map((p) => (
          <a class="workcard" href={`/projects/${p.id}/`}>
            <span class="shot">screenshot</span>
            <span class="body" style="display: block;">
              <span class="t">{p.data.title} {p.data.link && <small>{host(p.data.link)}</small>}</span>
              <p>{p.data.description}</p>
            </span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="wrap">
      <p class="seclabel">latest writing</p>
      {posts.map((post) => (
        <a class="postrow" href={`/writing/${post.id}/`}>
          <span class="grow">
            <span class="date">{iso(post.data.pubDate)}</span>
            <span class="t" style="display: block;">{post.data.title}</span>
          </span>
          <span class="go">→</span>
        </a>
      ))}
    </div>
  </section>
</Base>
