---
import { getCollection, render } from 'astro:content';
import Base from '../../layouts/Base.astro';
import Prompt from '../../components/Prompt.astro';

export async function getStaticPaths() {
  const projects = await getCollection('projects', ({ data }) => !data.draft);
  return projects.map((project) => ({ params: { slug: project.id }, props: { project } }));
}

const { project } = Astro.props;
const { Content } = await render(project);

const breadcrumbLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'projects', item: new URL('/projects/', Astro.site).href },
    { '@type': 'ListItem', position: 2, name: project.data.title.toLowerCase() },
  ],
};
---
<Base title={`${project.data.title} — lokilabs`} description={project.data.description}>
  <script type="application/ld+json" is:inline set:html={JSON.stringify(breadcrumbLd)} />
  <header class="site-header" slot="header">
    <div class="site-header__inner">
      <a class="backlink" href="/projects/"><span class="a">←</span> /lokilabs/projects</a>
      <a class="wordmark" href="/">/lokilabs <span class="prompt">$</span></a>
    </div>
  </header>
  <section class="hero-detail">
    <div class="wrap">
      <Prompt cmd="./run" cwd={`/lokilabs/${project.id}`} purple />
      <h1 style="text-transform: lowercase;">{project.data.title}</h1>
      <p class="sub">{project.data.description}</p>
      <div class="tags-purple">{project.data.tech.map((t) => <span class="tag">{t}</span>)}</div>
      <div class="btn-row">
        {project.data.link && <a class="btn" href={project.data.link}>visit {project.data.title} →</a>}
        {project.data.repo && <a class="btn ghost" href={project.data.repo}>github</a>}
      </div>
    </div>
  </section>
  <main id="main" class="wrap section">
    {project.data.screenshot && (
      <img
        class="project-shot"
        src={project.data.screenshot}
        alt={`${project.data.title} screenshot`}
        style="width: 100%; border-radius: 12px; border: 1px solid var(--line); display: block; margin-bottom: 30px;"
      />
    )}
    <div class="prose">
      <Content />
    </div>

    <section class="comments" aria-label="comments">
      <p class="seclabel" style="margin-top: 40px;">comments</p>
      <script
        is:inline
        src="https://giscus.app/client.js"
        data-repo="ronaldlokers/lokilabs.nl"
        data-repo-id="R_kgDOTee_gA"
        data-category="Announcements"
        data-category-id="DIC_kwDOTee_gM4DBuM9"
        data-mapping="pathname"
        data-strict="1"
        data-reactions-enabled="1"
        data-emit-metadata="0"
        data-input-position="bottom"
        data-theme="https://lokilabs.nl/giscus-theme.css"
        data-lang="en"
        data-loading="lazy"
        crossorigin="anonymous"
        async
      ></script>
    </section>
  </main>
</Base>
