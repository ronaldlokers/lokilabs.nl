---
import { getCollection, render } from 'astro:content';
import Base from '../layouts/Base.astro';
import { jobs, skills } from '../data/history';
import { fmtDate } from '../lib/date';
import '../styles/home.css';

const projects = (await getCollection('projects', ({ data }) => !data.draft))
  .sort((a, b) => a.data.order - b.data.order);
const posts = (await getCollection('writing', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const postDocs = await Promise.all(posts.map(async (p) => ({ p, Content: (await render(p)).Content })));
const projectDocs = await Promise.all(projects.map(async (p) => ({ p, Content: (await render(p)).Content })));
const slugName = (p: (typeof projects)[number]) => p.data.title.toLowerCase();
---

<Base
  title="lokilabs — Ronald Lokers"
  description="From TypeScript to Kubernetes: I build the tooling that keeps software boring to deploy, and write down what breaks along the way."
>
  <nav class="lk-nav" slot="header" aria-label="site">
    <a class="lk-brand" href="#lk-top">/lokilabs <span class="p">$</span></a>
    <div class="lk-navlinks">
      <a href="#lk-about">about</a>
      <a href="#lk-writing">writing</a>
      <a href="#lk-projects">projects</a>
      <a class="lk-cta" href="/cv/" data-lk="cv:cv">cv</a>
    </div>
  </nav>

  <main id="main" class="lk-home">
    <section id="lk-top" class="lk-hero" aria-label="intro">
      <canvas id="lk-glyphs" aria-hidden="true"></canvas>
      <div class="lk-hero-inner">
        <p class="lk-hero-prompt"><span class="u">ronald</span> <span class="a">→</span> <span class="d">~/lokilabs</span> <span class="a">$</span> <span class="c" id="lk-cmd">whoami</span></p>
        <h1 class="lk-hl">Do it twice?</h1>
        <p class="lk-hl l2">I’ll automate it<span class="lk-cursor" aria-hidden="true"></span></p>
        <p class="lk-hero-sub">from TypeScript to Kubernetes: i build the tooling that keeps software boring to deploy, and write down what breaks along the way.</p>
        <div class="lk-hero-meta">
          <a class="lk-open-badge" href="/cv/" data-lk="cv:cv"><span class="dot"></span>open to platform / devops roles</a>
        </div>
        <div class="lk-hero-cta">
          <a class="lk-btn" href="#lk-about">about me →</a>
          <a class="lk-btn ghost" href="/cv/" data-lk="cv:cv">open cv →</a>
        </div>
      </div>
    </section>

    <div class="lk-ticker" aria-hidden="true">
      <div class="lk-ticker-track">
        <span id="lk-tick-a"></span>
        <span id="lk-tick-b"></span>
      </div>
    </div>

    <section id="lk-about" class="lk-section about" aria-label="about">
      <div class="lk-sechead">
        <h2>about<span class="s">/</span></h2>
        <span class="cmd">$ whoami --verbose</span>
      </div>
      <div class="lk-term lk-io">
        <div class="lk-chrome">
          <span class="d1"></span><span class="d2"></span><span class="d3"></span>
          <span class="t">~/lokilabs — tmux: about</span>
        </div>
        <div class="lk-about-body">
          <div class="lk-about-txt">
            <div class="lk-promptline"><span class="u">ronald</span> <span class="a">→</span> ~/lokilabs <span class="a">$</span> cat about.md</div>
            <p>15 years of frontend and fullstack — Coolblue, Mendix, Oliver IT. somewhere along the way i noticed the part i actually loved was the pipelines underneath.</p>
            <p>so since mid-2025: all-in on platform engineering. the homelab is the lab — a gitops cluster on raspberry pi CM5s where everything on this page gets built, broken, and rebuilt.</p>
            <div class="lk-about-tl">
              <span><span class="y">2010–2025</span> — frontend / fullstack</span>
              <span><span class="y">2025–now</span> — platform / devops</span>
              <span><span class="y">always</span> — if it hurts, script it</span>
            </div>
          </div>
          <div class="lk-about-face">
            <div class="cmd"><span class="u">ronald</span> <span class="a">→</span> ~/lokilabs <span class="a">$</span> id --portrait</div>
            <div class="img"><img src="/assets/face-line-violet.png" alt="Ronald Lokers, line-art portrait" width="600" height="600" loading="lazy" /></div>
          </div>
        </div>
      </div>
    </section>

    <section id="lk-writing" class="lk-section" aria-label="writing">
      <div class="lk-sechead">
        <h2>writing<span class="s">/</span></h2>
        <span class="cmd">$ ls ~/lokilabs/writing — posts open right here</span>
      </div>
      <div class="lk-postlist">
        {posts.map((post, i) => (
          <a class="lk-post lk-io" style={`--i: ${i}`} href={`/writing/${post.id}/`} data-lk={`post:${post.id}`}>
            <span class="date">{fmtDate(post.data.pubDate)}</span>
            <span class="t">{post.data.title}</span>
            <span class="lk-arw" aria-hidden="true">→</span>
          </a>
        ))}
      </div>
    </section>

    <section id="lk-projects" class="lk-section projects" aria-label="projects">
      <div class="lk-sechead">
        <h2>projects<span class="s">/</span></h2>
        <span class="cmd">$ lokictl get projects — click one to open it</span>
      </div>
      <div class="lk-projgrid">
        {projects.map((p, i) => (
          <a class="lk-card lk-io" style={`--i: ${i % 3}`} href={`/projects/${p.id}/`} data-lk={`project:${p.id}`}>
            <span class="lk-chrome">
              <span class="d1"></span><span class="d2"></span><span class="d3"></span>
              <span class="t">~/lokilabs/projects/{slugName(p)}</span>
            </span>
            <span class="lk-card-body">
              <span class="lk-card-head">
                <span class="n">{slugName(p)}</span>
                {p.data.badge && <span class="lk-badge">{p.data.badge}</span>}
              </span>
              <span class="blurb">{p.data.description}</span>
              <span class="open">open →</span>
            </span>
          </a>
        ))}
      </div>
    </section>

    <div id="lk-overlay" hidden>
      <div class="lk-scrim"></div>
      <div class="lk-panel" role="dialog" aria-modal="true" aria-label="detail" tabindex="-1">
        <div class="lk-panel-head">
          <span class="lk-tl">
            <button class="close" title="close" type="button"><span>×</span></button>
            <button class="min" title="minimize" type="button"><span>−</span></button>
            <button class="max" title="maximize" type="button"><span>+</span></button>
          </span>
          <span class="lk-panel-title" id="lk-ptitle"></span>
        </div>
        <div id="lk-dbody"></div>
        <div id="lk-boot" hidden><pre id="lk-bootlog"></pre></div>
        <div class="lk-panel-foot">
          <div class="lk-foot-hint">
            <span><span class="u">ronald@lokilabs</span><span class="d">:~/lokilabs</span><span class="a">$</span></span>
            <span class="h">esc to close · scroll to read</span>
            <span class="lk-mini-cursor" aria-hidden="true"></span>
          </div>
          <a id="lk-prev" class="lk-foot-nav" href="#" hidden><span class="lbl"></span><span class="ttl"></span></a>
          <a id="lk-next" class="lk-foot-nav next" href="#" hidden><span class="ttl"></span><span class="lbl"></span></a>
        </div>
      </div>
    </div>

    <div id="lk-taskbar" hidden>
      <div class="lk-taskbrand">/lokilabs <span class="p">$</span></div>
      <div id="lk-taskstrip"></div>
      <span id="lk-taskcount"></span>
    </div>

    {postDocs.map(({ p, Content }) => (
      <template
        data-lk-tpl={`post:${p.id}`}
        data-title={p.data.title}
        data-tab={`~/lokilabs/writing/${p.id}.md`}
        data-dir="~/lokilabs/writing"
        data-file={`${p.id}.md`}
      >
        <div class="lk-doc">
          <div class="lk-doc-date">{fmtDate(p.data.pubDate)}</div>
          <h1>{p.data.title}</h1>
          <div class="prose"><Content /></div>
          <div class="lk-doc-end">$ wc -w → a few hundred · thanks for reading · <a href={`/writing/${p.id}/`}>permalink →</a></div>
        </div>
      </template>
    ))}

    {projectDocs.map(({ p, Content }) => (
      <template
        data-lk-tpl={`project:${p.id}`}
        data-title={slugName(p)}
        data-tab={`~/lokilabs/projects/${p.id} — README.md`}
        data-dir="~/lokilabs/projects"
        data-file={`${p.id}/README.md`}
      >
        <div class="lk-doc project">
          <div class="lk-doc-head">
            <h1>{slugName(p)}</h1>
            {p.data.badge && <span class="lk-badge">{p.data.badge}</span>}
          </div>
          <div class="lk-doc-desc">{p.data.description}</div>
          {p.data.tech.length > 0 && <div class="lk-doc-tags">{p.data.tech.map((t) => <span>{t}</span>)}</div>}
          <div class="prose"><Content /></div>
          <div class="lk-doc-links">
            {p.data.repo && <a class="repo" href={p.data.repo}>repo ↗</a>}
            {p.data.link && <a class="live" href={p.data.link}>live ↗</a>}
            <a class="page" href={`/projects/${p.id}/`}>full page &amp; comments →</a>
          </div>
        </div>
      </template>
    ))}

    <template
      data-lk-tpl="cv:cv"
      data-title="cv"
      data-tab="~/lokilabs/cv.md"
      data-dir="~/lokilabs"
      data-file="cv.md"
    >
      <div class="lk-doc">
        <h1>ronald lokers</h1>
        <div class="lk-cv-role">platform / devops engineer</div>
        <div class="lk-cv-actions">
          <a href="mailto:ronald@lokilabs.nl">get in touch</a>
          <a class="alt" href="https://www.linkedin.com/in/ronaldlokers/">linkedin ↗</a>
          <a class="alt" href="/cv/">full cv / print →</a>
        </div>
        <div class="lk-cv-summary">15+ years of engineering — frontend and fullstack at Coolblue, Mendix, and Oliver IT — with a career-long pull toward build tooling, CI/CD, and infrastructure. since mid-2025 fully committed to platform engineering. if i do something twice, it becomes a script.</div>
        <div class="lk-cv-skills">{skills.map((s) => <span>{s}</span>)}</div>
        <div class="lk-cv-jobs">
          {jobs.map((job) => (
            <div class="lk-cv-job">
              <div class="row">
                <span class="role">{job.role} <span class="org">@ {job.org}</span></span>
                <span class="dates">{job.when}</span>
              </div>
              {job.desc && <p>{job.desc}</p>}
            </div>
          ))}
        </div>
      </div>
    </template>
  </main>

  <footer id="lk-contact" class="lk-contact" slot="footer" aria-label="contact">
    <div class="lk-contact-inner">
      <div class="lk-contact-label">
        <span class="l">contact</span>
        <a class="lk-open-badge" href="/cv/" data-lk="cv:cv"><span class="dot"></span>open to new roles</a>
      </div>
      <p class="lk-contact-head">let’s automate something<span class="s">.</span></p>
      <div class="lk-contact-links">
        <a href="mailto:ronald@lokilabs.nl"><span class="p">$</span> mail <span class="v">ronald@lokilabs.nl</span></a>
        <a href="https://github.com/ronaldlokers"><span class="p">$</span> open <span class="v">github</span> ↗</a>
        <a href="https://www.linkedin.com/in/ronaldlokers/"><span class="p">$</span> open <span class="v">linkedin</span> ↗</a>
        <a href="/cv/" data-lk="cv:cv"><span class="p">$</span> curl <span class="v">cv</span> ↓</a>
      </div>
    </div>
    <div class="lk-contact-bar">
      <a class="top" href="#lk-top">↑ back to top</a>
      <span class="wm">/lokilabs <span class="p">$</span></span>
    </div>
  </footer>
</Base>

<script>
  import '../scripts/living-terminal.js';
</script>
