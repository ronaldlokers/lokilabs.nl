---
import { getCollection, render } from 'astro:content';
import Base from '../../layouts/Base.astro';

export async function getStaticPaths() {
  const posts = (await getCollection('writing', ({ data }) => !data.draft))
    .sort((a, b) => a.data.pubDate.valueOf() - b.data.pubDate.valueOf());
  return posts.map((post, i) => ({
    params: { slug: post.id },
    props: {
      post,
      older: posts[i - 1] ?? null,
      newer: posts[i + 1] ?? null,
      related: posts
        .filter((p) => p.id !== post.id && p.data.tags.some((t) => post.data.tags.includes(t)))
        .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
        .slice(0, 3),
    },
  }));
}

const { post, older, newer, related } = Astro.props;
const { Content } = await render(post);
import { fmtDate } from '../../lib/date';
const minutes = Math.max(1, Math.round((post.body ?? '').split(/\s+/).length / 200));

const articleLd = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: post.data.title,
  description: post.data.description,
  datePublished: post.data.pubDate.toISOString(),
  ...(post.data.updatedDate && { dateModified: post.data.updatedDate.toISOString() }),
  image: new URL(`/og/writing/${post.id}.png`, Astro.site).href,
  url: new URL(`/writing/${post.id}/`, Astro.site).href,
  mainEntityOfPage: new URL(`/writing/${post.id}/`, Astro.site).href,
  keywords: post.data.tags.join(', '),
  author: { '@type': 'Person', name: 'Ronald Lokers', url: 'https://lokilabs.nl' },
};
const breadcrumbLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'writing', item: new URL('/writing/', Astro.site).href },
    { '@type': 'ListItem', position: 2, name: post.data.title },
  ],
};
---
<Base title={`${post.data.title} — lokilabs`} description={post.data.description}>
  <script type="application/ld+json" is:inline set:html={JSON.stringify(articleLd)} />
  <script type="application/ld+json" is:inline set:html={JSON.stringify(breadcrumbLd)} />
  <header class="site-header" slot="header">
    <div class="site-header__inner">
      <a class="backlink" href="/writing/"><span class="a">←</span> /lokilabs/writing</a>
      <a class="wordmark" href="/">/lokilabs <span class="prompt">$</span></a>
    </div>
  </header>
  <section class="hero-detail">
    <div class="wrap">
      <p class="meta">{fmtDate(post.data.pubDate)} · {minutes} min · ronald{post.data.updatedDate && ` · updated ${fmtDate(post.data.updatedDate)}`}</p>
      <h1>{post.data.title}</h1>
      {post.data.tags.length > 0 && <div class="tags-purple">{post.data.tags.map((t) => <span class="tag">{t}</span>)}</div>}
    </div>
  </section>
  <main id="main" class="wrap section">
    <div class="prose">
      <Content />
    </div>

    {(older || newer) && (
      <nav class="postnav" aria-label="post navigation">
        {older
          ? <a class="postnav-card" href={`/writing/${older.id}/`}>
              <span class="dir">← older</span>
              <span class="pt">{older.data.title}</span>
            </a>
          : <span class="postnav-spacer"></span>}
        {newer
          ? <a class="postnav-card next" href={`/writing/${newer.id}/`}>
              <span class="dir">newer →</span>
              <span class="pt">{newer.data.title}</span>
            </a>
          : <span class="postnav-spacer"></span>}
      </nav>
    )}

    {related.length > 0 && (
      <section aria-label="related posts">
        <p class="seclabel" style="margin-top: 34px;">related</p>
        {related.map((p) => (
          <a class="postrow" href={`/writing/${p.id}/`}>
            <span class="grow">
              <span class="date">{fmtDate(p.data.pubDate)}</span>
              <span class="t" style="display: block;">{p.data.title}</span>
            </span>
            <span class="go">→</span>
          </a>
        ))}
      </section>
    )}
  </main>
</Base>
