---
import '@fontsource/fira-code/400.css';
import '@fontsource/fira-code/500.css';
import '@fontsource/fira-code/700.css';
import '../styles/global.css';
import '../styles/home.css';

interface Props {
  title: string;
  description: string;
  chrome?: boolean;
}
const { title, description, chrome = true } = Astro.props;
const canonical = new URL(Astro.url.pathname, Astro.site);
const path = Astro.url.pathname;
const ogSlug = path === '/' ? 'home' : path.replace(/^\/|\/$/g, '');
const ogImage = new URL(`/og/${ogSlug}.png`, Astro.site);
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <link rel="icon" href="/favicon.png" type="image/png" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/manifest.webmanifest" />
    <meta name="theme-color" content="#562C8B" />
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
    <link rel="alternate" type="application/rss+xml" title="lokilabs" href="/rss.xml" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:logo" content={new URL('/favicon.png', Astro.site)} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:image" content={ogImage} />
    <meta name="generator" content={Astro.generator} />
    <script type="application/ld+json" is:inline set:html={JSON.stringify({
      '@context': 'https://schema.org',
      '@type': 'Person',
      name: 'Ronald Lokers',
      jobTitle: 'Platform / DevOps Engineer',
      url: 'https://lokilabs.nl',
      email: 'mailto:ronald@lokilabs.nl',
      sameAs: [
        'https://github.com/ronaldlokers',
        'https://www.linkedin.com/in/ronaldlokers',
      ],
    })} />
    <script defer is:inline src="https://static.cloudflareinsights.com/beacon.min.js" data-cf-beacon='{"token": "7963c7055a374937acd09a9a2535f60d"}'></script>
  </head>
  <body>
    <a class="skip-link" href="#main">skip to content</a>
    {chrome ? (
      <slot name="header">
        <nav class="lk-nav" aria-label="site">
          <a class="lk-brand" href="/">/lokilabs <span class="p">$</span></a>
          <div class="lk-navlinks">
            <a href="/about/" data-lk="section:about">about</a>
            <a href="/writing/" data-lk="section:writing">writing</a>
            <a href="/projects/" data-lk="section:projects">projects</a>
            <a class="lk-cta" href="/cv/" data-lk="cv:cv">cv</a>
          </div>
        </nav>
      </slot>
    ) : (
      <slot name="header" />
    )}
    <slot />
    {chrome ? (
      <slot name="footer">
        <footer id="lk-contact" class="lk-contact" aria-label="contact">
          <div class="lk-contact-inner">
            <div class="lk-contact-label">
              <span class="l">contact</span>
              <a class="lk-open-badge" href="/cv/" data-lk="cv:cv"><span class="dot"></span>open to new roles</a>
            </div>
            <p class="lk-contact-head">let’s automate something<span class="s">.</span></p>
            <div class="lk-contact-links">
              <a href="mailto:ronald@lokilabs.nl"><span class="p">$</span> mail <span class="v">ronald@lokilabs.nl</span></a>
              <a href="https://github.com/ronaldlokers"><span class="p">$</span> open <span class="v">github</span> ↗</a>
              <a href="https://www.linkedin.com/in/ronaldlokers/"><span class="p">$</span> open <span class="v">linkedin</span> ↗</a>
              <a href="/cv/" data-lk="cv:cv"><span class="p">$</span> curl <span class="v">cv</span> ↓</a>
            </div>
          </div>
          <div class="lk-contact-bar">
            <a class="top" href="#lk-top">↑ back to top</a>
            <span class="wm">/lokilabs <span class="p">$</span></span>
          </div>
        </footer>
      </slot>
    ) : (
      <slot name="footer" />
    )}
    <script>
      import '../scripts/living-terminal.js';
    </script>
  </body>
</html>
