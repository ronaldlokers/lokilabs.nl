---
import Base from '../layouts/Base.astro';
import { jobs, education, skills } from '../data/history';
---
<Base title="cv — Ronald Lokers" description="CV of Ronald Lokers — platform / devops engineer with 15+ years of engineering experience.">
  <main class="wrap page-head cv">
    <div class="cv-top">
      <div>
        <h1>Ronald Lokers</h1>
        <p class="cv-role">Platform / DevOps Engineer</p>
        <p class="cv-contact">
          <a href="mailto:ronald@lokilabs.nl">ronald@lokilabs.nl</a> ·
          <a href="https://lokilabs.nl">lokilabs.nl</a> ·
          <a href="https://github.com/ronaldlokers">github.com/ronaldlokers</a> ·
          <a href="https://www.linkedin.com/in/ronaldlokers">linkedin.com/in/ronaldlokers</a>
        </p>
      </div>
      <div class="cv-actions">
        <span class="hire-badge">open to platform / devops roles</span>
        <button class="btn cv-print" onclick="window.print()">print / save pdf</button>
      </div>
    </div>

    <p class="seclabel">summary</p>
    <p class="cv-summary">
      15+ years of engineering — frontend and fullstack at Coolblue, Mendix, and
      Oliver IT — with a career-long pull toward build tooling, CI/CD, and
      infrastructure. Since mid-2025 fully committed to platform engineering:
      I run a multi-node HA Kubernetes cluster like production, GitOps
      end-to-end, with full observability. If I do something twice, it becomes
      a script.
    </p>

    <p class="seclabel">skills</p>
    <ul class="cv-skills">
      {skills.map((s) => <li>{s}</li>)}
    </ul>

    <p class="seclabel">experience</p>
    <div class="cv-jobs">
      {jobs.map((job) => (
        <div class="cv-job">
          <div class="when">{job.when}</div>
          <div>
            <div class="role">{job.role} <small>@ {job.org}</small></div>
            {job.desc && <p>{job.desc}</p>}
          </div>
        </div>
      ))}
    </div>

    <p class="seclabel">education</p>
    <div class="cv-jobs">
      {education.map((e) => (
        <div class="cv-job">
          <div class="when">{e.when}</div>
          <div>
            <div class="role">{e.what} <small>@ {e.where}</small></div>
          </div>
        </div>
      ))}
    </div>

    <p class="seclabel">selected projects</p>
    <div class="cv-jobs">
      <div class="cv-job"><div class="when">homelab</div><div><p>HA k3s cluster on Raspberry Pi CM5 — FluxCD GitOps, Longhorn, MetalLB, Prometheus/Grafana. <span class="cv-url">github.com/ronaldlokers/homelab</span></p></div></div>
      <div class="cv-job"><div class="when">zenith</div><div><p>Job-hunt pipeline tracker — TypeScript on Cloudflare's free tier. <span class="cv-url">zenith.lokilabs.nl</span></p></div></div>
      <div class="cv-job"><div class="when">walkfit</div><div><p>Browser treadmill control over Web Bluetooth — Vue 3, CI/E2E pipelines. <span class="cv-url">ronaldlokers.github.io/WalkFit</span></p></div></div>
    </div>
  </main>
</Base>
