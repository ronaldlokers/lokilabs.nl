# security headers — site-wide. CSP allows the two external scripts actually
# loaded (Cloudflare's RUM beacon, giscus's client.js) plus 'self'; giscus
# renders inside its own iframe (frame-src) so its own CSP governs what
# loads inside it, not this one. style-src keeps 'unsafe-inline' since the
# templates use plenty of inline style="" attributes — stripping those is a
# separate, larger refactor, not bundled into this pass.
/*
  Content-Security-Policy: default-src 'self'; script-src 'self' https://static.cloudflareinsights.com https://giscus.app; style-src 'self' 'unsafe-inline' https://giscus.app; img-src 'self' data:; font-src 'self' data:; connect-src 'self' https://cloudflareinsights.com; frame-src https://giscus.app; frame-ancestors 'self'; base-uri 'self'; form-action 'self'; object-src 'none'; upgrade-insecure-requests
  X-Frame-Options: SAMEORIGIN
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Strict-Transport-Security: max-age=31536000; includeSubDomains
  Permissions-Policy: camera=(), microphone=(), geolocation=()

# hashed build assets — safe to cache forever
/_astro/*
  Cache-Control: public, max-age=31536000, immutable

# images and icons — unhashed, cache a day at the edge/browser
/assets/*
  Cache-Control: public, max-age=86400

# fonts served cross-origin into the giscus iframe
/assets/fonts/*
  Access-Control-Allow-Origin: *
  Cache-Control: public, max-age=31536000, immutable

/giscus-theme.css
  Access-Control-Allow-Origin: *
  Cache-Control: public, max-age=86400

/og/*
  Cache-Control: public, max-age=86400

/favicon.png
  Cache-Control: public, max-age=86400

/apple-touch-icon.png
  Cache-Control: public, max-age=86400

/icon-192.png
  Cache-Control: public, max-age=86400

/icon-512.png
  Cache-Control: public, max-age=86400
