{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "lokilabs-nl",
  "compatibility_date": "2026-07-20",
  "main": "src/worker/index.js",
  "assets": {
    "directory": "./dist",
    "binding": "ASSETS",
    "not_found_handling": "404-page",
    "run_worker_first": ["/api/*"]
  },
  "kv_namespaces": [
    {
      "binding": "TICKER_KV",
      "id": "7f6485f2b0f744baafd8f2b32beae1b8"
    }
  ],
  "triggers": {
    "crons": ["0 * * * *"]
  }
}
