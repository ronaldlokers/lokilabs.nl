---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';
import Prompt from '../../components/Prompt.astro';

const projects = (await getCollection('projects', ({ data }) => !data.draft))
  .sort((a, b) => a.data.order - b.data.order);
const host = (url: string) => new URL(url).host;
---
<Base title="projects — lokilabs" description="Things Ronald Lokers builds.">
  <main id="main" class="wrap page-head">
    <Prompt cmd="ls projects/" />
    <h1>projects</h1>
    <div>
      {projects.map((p) => (
        <a class="projcard" href={`/projects/${p.id}/`}>
          <span class="avatar">
            {p.data.screenshot
              ? <img src={p.data.screenshot} alt="" loading="lazy" />
              : p.data.title.charAt(0).toLowerCase()}
          </span>
          <span class="grow">
            <span class="t">
              {p.data.title} {p.data.badge && <span class="badge">{p.data.badge}</span>} {p.data.link && <small>→ {host(p.data.link)}</small>}
            </span>
            <p>{p.data.description}</p>
            <span class="tags">{p.data.tech.map((t) => <span class="tag">{t}</span>)}</span>
          </span>
          <span class="go">→</span>
        </a>
      ))}
    </div>
  </main>
</Base>
